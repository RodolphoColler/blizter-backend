{
  "name": "blizter-backend",
  "version": "1.0.0",
  "description": "",
  "main": "./build/server.js",
  "scripts": {
    "build": "npx --package typescript tsc --init",
    "test": "mocha -r ts-node/register ./src/tests/*.{test,spec}.ts -t 10000 --exit",
    "prestart": "npm run build",
    "start": "node build/server.js",
    "dev": "nodemon --watch \"./src/**\" --ext \"ts,js\" --ignore \"src/**/*.spec.ts,src/**/*.json\" --exec \"ts-node src/server.ts\"",
    "deploy": "git add . && git commit -m Heroku && git push heroku main:master"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RodolphoColler/blizter-backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/RodolphoColler/blizter-backend/issues"
  },
  "homepage": "https://github.com/RodolphoColler/blizter-backend#readme",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chai-http": "^4.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "eslint-import-resolver-typescript": "^2.7.1",
    "express": "^4.18.1",
    "joi": "^17.6.0",
    "jsonwebtoken": "^8.5.1",
    "nodemon": "^2.0.16"
  },
  "devDependencies": {
    "@joi/date": "^2.1.0",
    "@prisma/client": "^3.14.0",
    "@types/chai": "^4.3.1",
    "@types/express": "^4.17.13",
    "@types/mocha": "^9.1.1",
    "@types/node": "^17.0.36",
    "@types/sinon": "^10.0.11",
    "@types/bcryptjs": "^2.4.2",
    "@types/chai-http": "^4.2.0",
    "@types/cors": "^2.8.12",
    "@types/jsonwebtoken": "^8.5.8",
    "@typescript-eslint/eslint-plugin": "^5.27.0",
    "@typescript-eslint/parser": "^5.27.0",
    "chai": "^4.3.6",
    "eslint": "^8.16.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.26.0",
    "mocha": "^10.0.0",
    "prisma": "^3.14.0",
    "sinon": "^14.0.0",
    "ts-node": "^10.8.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.7.2"
  }
}
